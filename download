.subtitle { font-size: 16px; color: var(--text-2); max-width: 720px; }
.hero-metrics { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 1px; background: var(--border); border: 1px solid var(--border); margin-bottom: 56px; }
.hero-metric { background: var(--bg-card); padding: 28px 32px; display: flex; flex-direction: column; gap: 12px; }
.hero-metric.primary { background: linear-gradient(135deg, var(--bg-2) 0%, var(--bg-3) 100%); position: relative; overflow: hidden; }
.hero-metric.primary::after { content: ''; position: absolute; top: 0; right: 0; width: 200px; height: 200px; background: radial-gradient(circle, rgba(212,175,55,0.06) 0%, transparent 70%); pointer-events: none; }
.metric-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-3); font-weight: 500; }
.metric-value { font-family: var(--serif); font-size: 38px; font-weight: 400; line-height: 1; letter-spacing: -0.02em; }
.hero-metric.primary .metric-value { font-size: 52px; }
.metric-sub { font-family: var(--mono); font-size: 12px; color: var(--text-2); letter-spacing: 0.02em; }
.metric-pl { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
.metric-pl .pct { font-family: var(--mono); font-size: 14px; font-weight: 500; }
.green { color: var(--green); } .red { color: var(--red); }
