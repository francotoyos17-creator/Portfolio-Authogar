.header { border-bottom: 1px solid var(--border); padding-bottom: 32px; margin-bottom: 40px; }
.brand-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; }
.brand-line { display: flex; align-items: center; gap: 12px; }
.brand-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 12px var(--accent); }
.brand { font-family: var(--serif); font-weight: 500; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-3); }
.timestamp { font-family: var(--mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.05em; }
